PORT=5000
NODE_ENV=development
JWT_SECRET="shomeus_jwt_super_secret_2025"

# ─── Database (local PostgreSQL for dev) ──────────────────────────────────────
# For local dev: install PostgreSQL locally and create a database named "shomeus"
# Then run: npx prisma migrate dev
# Production: Render injects DATABASE_URL automatically from the managed DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shomeus?sslmode=disable"

# ─── Payments ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_PLACEHOLDER"
RAZORPAY_KEY_SECRET="PLACEHOLDER_SECRET"
RAZORPAY_WEBHOOK_SECRET="PLACEHOLDER_WEBHOOK_SECRET"
